{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "team-task.schema.json",
  "title": "우리팀 과제",
  "description": "팀장이 팀원에게 부여하는 과제. data/team/tasks.json은 이 스키마를 따르는 객체의 배열이다. 완료 체크를 팀원이 직접 하는 것은 STEP 3(엣지 연동)에서 열리며, 그 전에는 팀장이 상태를 갱신한다. 고객 언급은 코드(C-YYYY-NNN)로만 한다.",
  "type": "object",
  "required": ["id", "제목", "대상", "부여일", "상태"],
  "properties": {
    "id": { "type": "string", "pattern": "^t-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}$", "description": "과제 ID (예: t-2026-07-19-01)" },
    "제목": { "type": "string" },
    "내용": { "type": ["string", "null"], "description": "과제 설명 (선택)" },
    "대상": {
      "description": "부여 대상. \"전체\" 또는 members.json 팀원 id 배열",
      "oneOf": [
        { "type": "string", "const": "전체" },
        { "type": "array", "items": { "type": "string", "pattern": "^m-[0-9]{2}$" }, "minItems": 1 }
      ]
    },
    "부여일": { "type": "string", "format": "date" },
    "기한": { "type": ["string", "null"], "format": "date", "description": "마감일 (선택). 지나면 화면에 강조 표시" },
    "상태": { "type": "string", "enum": ["요청", "진행중", "완료"] },
    "연결": {
      "type": "array",
      "description": "관련 플랫폼 화면 링크",
      "items": {
        "type": "object",
        "required": ["라벨", "경로"],
        "properties": { "라벨": { "type": "string" }, "경로": { "type": "string" } }
      }
    }
  }
}
