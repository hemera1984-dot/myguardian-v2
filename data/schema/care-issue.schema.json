{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "care-issue.schema.json",
  "title": "케어센터 발행물",
  "description": "주간·월간 안창민 발행물 메타데이터. data/care/issues.json은 이 스키마를 따르는 객체의 배열이다. 본문은 data/care/issues/<id>.html 조각 파일로 둔다. 고객 개인정보 금지.",
  "type": "object",
  "required": ["id", "채널", "호수", "제목", "발행일", "본문파일"],
  "properties": {
    "id": {
      "type": "string",
      "description": "발행물 고유 ID. 안창민 호는 weekly-11 형식, 팀원 호는 발행인 식별자를 끼운 weekly-kse-01 형식",
      "pattern": "^(weekly|monthly)(-[a-z0-9]+)?-[0-9]{2}$"
    },
    "발행인": {
      "type": "string",
      "description": "발행 설계사 이름. 제호(주간 OOO)·킥커·한마디 라벨·카톡 문구에 쓰인다",
      "default": "안창민"
    },
    "채널": {
      "type": "string",
      "enum": ["주간", "월간"],
      "description": "주간 안창민 / 월간 안창민"
    },
    "호수": {
      "type": "integer",
      "minimum": 1,
      "description": "발행 호수"
    },
    "제목": {
      "type": "string",
      "description": "호 제목"
    },
    "발행일": {
      "type": "string",
      "format": "date",
      "description": "발행 일자 (YYYY-MM-DD)"
    },
    "요약": {
      "type": ["string", "null"],
      "description": "한두 문장 요약. 아카이브 목록과 카톡 문구에 사용"
    },
    "본문파일": {
      "type": "string",
      "description": "본문 HTML 조각 파일 경로. 사이트 루트 기준 (예: data/care/issues/weekly-11.html)"
    },
    "커버이미지": {
      "type": ["string", "null"],
      "description": "커버 이미지 경로. 없으면 미표시"
    },
    "카톡문구": {
      "type": ["string", "null"],
      "description": "카톡 발송 문구 직접 지정(선택). 없으면 채널별 표준 양식으로 생성한다. 발신자 서명은 화면 설정(localStorage)에서 가져온다"
    },
    "주차라벨": {
      "type": ["string", "null"],
      "description": "표시용 발행 라벨 (예: 2026년 7월 2주차 / 2026년 7월호)"
    },
    "원문링크": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "v1(마누스 웹) 원문 URL. 이관 호에만 존재"
    },
    "꼭지": {
      "type": "array",
      "description": "기사·칼럼 목록. 카톡 문구 생성에 사용",
      "items": {
        "type": "object",
        "required": ["번호", "제목"],
        "properties": {
          "번호": { "type": "integer" },
          "카테고리": { "type": "string" },
          "제목": { "type": "string" },
          "부제": { "type": "string" }
        }
      }
    }
  }
}
