{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "care-body.schema.json",
  "title": "케어센터 발행물 본문",
  "description": "data/care/issues/<id>.json 구조. 발행 전 publish_care_issue.py가 이 규격을 코드로 검증한다. 기사 수는 주간 4·월간 3, 기사 번호는 1부터 연속·유일.",
  "type": "object",
  "required": ["id", "편집장의말", "기사"],
  "properties": {
    "id": {
      "type": "string",
      "description": "issues.json 메타의 id와 일치해야 한다",
      "pattern": "^(weekly|monthly)(-[a-z0-9]+)?-[0-9]{2}$"
    },
    "편집장의말": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "문단 배열. 서명은 항상 편집장 안창민"
    },
    "기사": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["번호", "카테고리", "제목", "부제", "요약", "본문"],
        "properties": {
          "번호": { "type": "integer", "minimum": 1 },
          "카테고리": { "type": "string" },
          "제목": { "type": "string", "minLength": 1 },
          "부제": { "type": "string", "minLength": 1 },
          "요약": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "한마디": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "description": "발행인 한마디 문단 배열 (선택)"
          },
          "본문": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["t", "x"],
              "properties": {
                "t": { "type": "string", "enum": ["h", "p"], "description": "h=소제목, p=문단" },
                "x": { "type": "string", "minLength": 1 }
              }
            }
          },
          "이미지": {
            "type": ["string", "null"],
            "description": "기사 삽화 경로. 존재하는 파일이어야 한다"
          }
        }
      }
    }
  }
}
